# MongoDB connection string
MONGODB_URI=mongodb+srv://your-connection-string

# JWT secret for admin/worker auth tokens
JWT_SECRET=your-jwt-secret-key

# Secret used to generate and validate daily attendance QR codes
QR_SECRET=your-qr-secret-key

# Admin seed credentials (used by GET /api/seed to create the default admin)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@areej.com
ADMIN_PASSWORD=admin123
